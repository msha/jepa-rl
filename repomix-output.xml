<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JEPA-RL Breakout</title>
    <style>
      :root {
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #111318;
        color: #f4f6fb;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
      }

      main {
        width: min(92vw, 720px);
      }

      body.embed {
        overflow: hidden;
        min-height: auto;
        background: transparent;
      }
      body.embed main {
        width: 100%;
      }
      body.embed header, body.embed #status {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
      }
      body.embed canvas {
        width: 100%;
        height: auto;
        aspect-ratio: 4 / 3;
      }

      header, #status {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
      }

      header.hidden-default {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 10px;
      }

      h1 {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
      }

      .stats {
        display: flex;
        gap: 14px;
        font-variant-numeric: tabular-nums;
        font-size: 14px;
      }

      canvas {
        display: block;
        width: 100%;
        aspect-ratio: 4 / 3;
        background: #07090d;
        border: 1px solid #2d3442;
        outline: none;
      }

      body.embed canvas {
        background: transparent;
        border-color: transparent;
      }

      #status {
        min-height: 22px;
        margin-top: 8px;
        color: #aeb8ca;
        font-size: 13px;
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>JEPA-RL Breakout</h1>
        <div class="stats">
          <span>Score <strong id="score">0</strong></span>
          <span>Lives <strong id="lives">3</strong></span>
        </div>
      </header>
      <canvas id="game" width="640" height="480" tabindex="0"></canvas>
      <div id="status" data-state="playing">Playing</div>
    </main>

    <script>
      const canvas = document.getElementById("game");
      const ctx = canvas.getContext("2d");
      const scoreEl = document.getElementById("score");
      const livesEl = document.getElementById("lives");
      const statusEl = document.getElementById("status");

      const keys = new Set();
      const paddle = {
        x: 270, y: 438, w: 100, h: 14,
        vx: 0,
        accel: 0.8,
        friction: 0.82,
        maxSpeed: 8,
      };

      const BASE_BALL_SPEED = 3.8;
      const MAX_BALL_SPEED = 6.0;
      const MAX_BOUNCE_ANGLE = Math.PI / 3; // 60 degrees

      const ball = { x: 320, y: 330, r: 8, vx: 0, vy: 0 };

      const brickRows = 5;
      const brickCols = 10;
      const brickGap = 6;
      const brickW = 58;
      const brickH = 18;
      const brickOffsetX = Math.floor((canvas.width - brickCols * brickW - (brickCols - 1) * brickGap) / 2);
      const brickOffsetY = 52;
      const TILES_DESTROYED_THRESHOLD = 15;
      const MIN_TILES = 25;
      const DANGER_Y = 360;

      const REF_DT = 1000 / 60;
      let lastFrameTime = 0;

      let bricks = [];
      let particles = [];
      let flashes = [];
      let score = 0;
      let lives = 3;
      let wave = 1;
      let done = false;
      let serving = true;
      let waiting = true;
      let tilesDestroyedSinceLastRow = 0;
      let gameStartTime = 0;
      let actionCount = 0;
      const BOARD_KEY = "jeparl_breakout";

      function postScores(scores) {
        try { window.parent.postMessage({ type: "jeparl-scores", game: BOARD_KEY, scores: scores || loadBoard() }, "*"); } catch {}
      }

      function isAI() { return new URLSearchParams(window.location.search).has("run_name"); }

      function getPlayerLabel() {
        const params = new URLSearchParams(window.location.search);
        if (isAI()) {
          const run = params.get("run_name") || "";
          const ckpt = params.get("checkpoint") || "";
          if (run && ckpt) return run + " · " + ckpt;
          if (run) return run;
          return "AI";
        }
        return params.get("player_name") || "HUMAN";
      }

      function getMetadata() {
        const params = new URLSearchParams(window.location.search);
        return {
          algorithm: params.get("algorithm") || "",
          encoder: params.get("encoder") || "",
          latent_dim: params.get("latent_dim") || "",
          steps_trained: params.get("steps_trained") || ""
        };
      }

      function loadBoard() {
        try { return JSON.parse(localStorage.getItem(BOARD_KEY) || "[]"); }
        catch { return []; }
      }

      function saveToBoard(s) {
        if (s <= 0) return loadBoard();
        const scores = loadBoard();
        const elapsed = gameStartTime > 0 ? (Date.now() - gameStartTime) / 1000 : 0;
        const apm = elapsed > 0 ? Math.round(actionCount / (elapsed / 60)) : 0;
        const entry = { score: s, player: getPlayerLabel(), type: isAI() ? "ai" : "human", date: new Date().toISOString(), apm: apm };
        if (isAI()) Object.assign(entry, getMetadata());
        scores.push(entry);
        scores.sort((a, b) => b.score - a.score);
        if (scores.length > 10) scores.length = 10;
        try { localStorage.setItem(BOARD_KEY, JSON.stringify(scores)); } catch {}
        postScores(scores);
        return scores;
      }

      function ballSpeed() {
        return Math.min(BASE_BALL_SPEED + (wave - 1) * 0.15, MAX_BALL_SPEED);
      }

      function brickHPForWave(row, currentWave) {
        // first 5 waves: all normal
        if (currentWave <= 5) return 1;
        // after wave 5: chance of fortified increases with wave number
        const fortChance = Math.min(0.8, (currentWave - 5) * 0.08);
        // top rows more likely to be fortified
        const rowBias = (brickRows - row) / brickRows;
        if (Math.random() < fortChance * rowBias) {
          return Math.min(3, 1 + Math.floor((currentWave - 5) / 4));
        }
        return 1;
      }

      function resetBricks() {
        bricks = [];
        for (let row = 0; row < brickRows; row += 1) {
          for (let col = 0; col < brickCols; col += 1) {
            const hp = 1;
            bricks.push({
              x: brickOffsetX + col * (brickW + brickGap),
              y: brickOffsetY + row * (brickH + brickGap),
              w: brickW,
              h: brickH,
              alive: true,
              row,
              hp,
              maxHP: hp,
            });
          }
        }
      }

      function spawnSingleRow() {
        const rowH = brickH + brickGap;
        for (const b of bricks) {
          if (b.alive) b.y += rowH;
        }
        bricks = bricks.filter((b) => b.alive);
        for (const b of bricks) {
          if (b.y + b.h >= DANGER_Y) {
            setDone("Done");
            return;
          }
        }
        wave += 1;
        for (let col = 0; col < brickCols; col++) {
          const hp = brickHPForWave(0, wave);
          bricks.push({
            x: brickOffsetX + col * (brickW + brickGap),
            y: brickOffsetY,
            w: brickW,
            h: brickH,
            alive: true,
            row: 0,
            hp,
            maxHP: hp,
          });
        }
        tilesDestroyedSinceLastRow = 0;
      }

      function isBottomRowGone() {
        let maxY = -1;
        for (const b of bricks) {
          if (b.y > maxY) maxY = b.y;
        }
        if (maxY < 0) return true;
        return !bricks.some((b) => b.alive && b.y === maxY);
      }

      function checkAndSpawnRows() {
        let spawns = 0;
        while (spawns < 3 && !done) {
          const alive = bricks.filter((b) => b.alive).length;
          if (alive < MIN_TILES || tilesDestroyedSinceLastRow >= TILES_DESTROYED_THRESHOLD || isBottomRowGone()) {
            spawnSingleRow();
            spawns++;
          } else {
            break;
          }
        }
      }

      function serveBall() {
        serving = true;
        ball.vx = 0;
        ball.vy = 0;
        ball.x = paddle.x + paddle.w / 2;
        ball.y = paddle.y - ball.r - 2;
      }

      function launchBall() {
        const speed = ballSpeed();
        const angle = (Math.random() - 0.5) * Math.PI / 3;
        ball.vx = speed * Math.sin(angle);
        ball.vy = -speed * Math.cos(angle);
        serving = false;
      }

      function resetGame() {
        score = 0;
        lives = 3;
        wave = 1;
        done = false;
        waiting = true;
        tilesDestroyedSinceLastRow = 0;
        actionCount = 0;
        gameStartTime = 0;
        paddle.x = 270;
        paddle.vx = 0;
        particles = [];
        flashes = [];
        resetBricks();
        serveBall();
        statusEl.dataset.state = "playing";
        statusEl.textContent = "Playing";
        updateStats();
      }

      function updateStats() {
        scoreEl.textContent = String(score);
        livesEl.textContent = String(lives);
      }

      function setDone(text) {
        done = true;
        saveToBoard(score);
        statusEl.dataset.state = "done";
        statusEl.textContent = text;
      }

      function spawnParticles(x, y, color, count) {
        for (let i = 0; i < count; i += 1) {
          const angle = Math.random() * Math.PI * 2;
          const speed = 1 + Math.random() * 2.5;
          particles.push({
            x, y,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            life: 1.0,
            decay: 0.03 + Math.random() * 0.02,
            size: 2 + Math.random() * 3,
            color,
          });
        }
      }

      window.addEventListener("keydown", (event) => {
        const k = event.key;
        const mapped = k === 'w' || k === 'W' ? 'ArrowUp'
                     : k === 'a' || k === 'A' ? 'ArrowLeft'
                     : k === 's' || k === 'S' ? 'ArrowDown'
                     : k === 'd' || k === 'D' ? 'ArrowRight'
                     : k;
        keys.add(mapped);
        if (!waiting && !done) actionCount++;
        if (mapped === " ") {
          event.preventDefault();
          if (waiting && !done) {
            waiting = false;
            gameStartTime = Date.now();
            return;
          }
          if (serving && !done) {
            launchBall();
          }
        }
        if ((mapped === "r") && done) {
          resetGame();
        }
        if (mapped === "ArrowLeft" || mapped === "ArrowRight") {
          event.preventDefault();
        }
      });

      window.addEventListener("keyup", (event) => {
        const k = event.key;
        const mapped = k === 'w' || k === 'W' ? 'ArrowUp'
                     : k === 'a' || k === 'A' ? 'ArrowLeft'
                     : k === 's' || k === 'S' ? 'ArrowDown'
                     : k === 'd' || k === 'D' ? 'ArrowRight'
                     : k;
        keys.delete(mapped);
      });

      function rectHitCircle(rect, circle) {
        const closestX = Math.max(rect.x, Math.min(circle.x, rect.x + rect.w));
        const closestY = Math.max(rect.y, Math.min(circle.y, rect.y + rect.h));
        const dx = circle.x - closestX;
        const dy = circle.y - closestY;
        return dx * dx + dy * dy <= circle.r * circle.r;
      }

      function update(dt) {
        if (done) return;

        if (waiting) return;

        // Paddle: acceleration-based movement
        if (keys.has("ArrowLeft")) {
          paddle.vx -= paddle.accel * dt;
        } else if (keys.has("ArrowRight")) {
          paddle.vx += paddle.accel * dt;
        } else {
          paddle.vx *= Math.pow(paddle.friction, dt);
        }
        paddle.vx = Math.max(-paddle.maxSpeed, Math.min(paddle.maxSpeed, paddle.vx));
        if (Math.abs(paddle.vx) < 0.1 && !keys.has("ArrowLeft") && !keys.has("ArrowRight")) {
          paddle.vx = 0;
        }
        paddle.x += paddle.vx * dt;
        paddle.x = Math.max(0, Math.min(canvas.width - paddle.w, paddle.x));

        // Ball follows paddle while serving
        if (serving) {
          ball.x = paddle.x + paddle.w / 2;
          ball.y = paddle.y - ball.r - 2;
          return;
        }

        ball.x += ball.vx * dt;
        ball.y += ball.vy * dt;

        // Wall bounces
        if (ball.x <= ball.r) {
          ball.vx = Math.abs(ball.vx);
          ball.x = ball.r;
        }
        if (ball.x >= canvas.width - ball.r) {
          ball.vx = -Math.abs(ball.vx);
          ball.x = canvas.width - ball.r;
        }
        if (ball.y <= ball.r) {
          ball.vy = Math.abs(ball.vy);
          ball.y = ball.r;
        }

        // Paddle collision
        if (rectHitCircle(paddle, ball) && ball.vy > 0) {
          const hit = (ball.x - (paddle.x + paddle.w / 2)) / (paddle.w / 2);
          const clampedHit = Math.max(-1, Math.min(1, hit));
          const angle = clampedHit * MAX_BOUNCE_ANGLE;
          const speed = ballSpeed();
          ball.vx = speed * Math.sin(angle);
          ball.vy = -speed * Math.cos(angle);
          ball.y = paddle.y - ball.r - 1;
        }

        // Brick collisions — check all bricks, proper face detection
        for (const brick of bricks) {
          if (!brick.alive || !rectHitCircle(brick, ball)) continue;

          brick.hp -= 1;

          // Determine which face was hit
          const overlapLeft = (ball.x + ball.r) - brick.x;
          const overlapRight = (brick.x + brick.w) - (ball.x - ball.r);
          const overlapTop = (ball.y + ball.r) - brick.y;
          const overlapBottom = (brick.y + brick.h) - (ball.y - ball.r);

          const minOverlapX = Math.min(overlapLeft, overlapRight);
          const minOverlapY = Math.min(overlapTop, overlapBottom);

          if (minOverlapX < minOverlapY) {
            ball.vx *= -1;
            ball.x += (overlapLeft < overlapRight ? -minOverlapX : minOverlapX);
          } else {
            ball.vy *= -1;
            ball.y += (overlapTop < overlapBottom ? -minOverlapY : minOverlapY);
          }

          if (brick.hp <= 0) {
            brick.alive = false;
            tilesDestroyedSinceLastRow++;
            score += 5 + (brickRows - brick.row);
            const colors = ["#27d6a0", "#64a8ff", "#ffd166", "#ff5a7a", "#c084fc"];
            spawnParticles(brick.x + brick.w / 2, brick.y + brick.h / 2, colors[brick.row % colors.length], 8);
          } else {
            score += 2;
            flashes.push({ x: brick.x, y: brick.y, w: brick.w, h: brick.h, life: 0.5 });
          }
          flashes.push({ x: brick.x, y: brick.y, w: brick.w, h: brick.h, life: brick.hp <= 0 ? 1.0 : 0.5 });
        }

        // Cap ball speed
        const currentSpeed = Math.sqrt(ball.vx * ball.vx + ball.vy * ball.vy);
        if (currentSpeed > MAX_BALL_SPEED) {
          ball.vx = (ball.vx / currentSpeed) * MAX_BALL_SPEED;
          ball.vy = (ball.vy / currentSpeed) * MAX_BALL_SPEED;
        }

        // Ball lost
        if (ball.y > canvas.height + ball.r) {
          lives -= 1;
          if (lives <= 0) {
            setDone("Done");
          } else {
            serveBall();
          }
        }

        // Row spawning
        if (!done) {
          checkAndSpawnRows();
        }

        // Update particles
        for (let i = particles.length - 1; i >= 0; i -= 1) {
          const p = particles[i];
          p.x += p.vx * dt;
          p.y += p.vy * dt;
          p.vy += 0.05 * dt;
          p.life -= p.decay * dt;
          if (p.life <= 0) particles.splice(i, 1);
        }

        // Update flashes
        for (let i = flashes.length - 1; i >= 0; i -= 1) {
          flashes[i].life -= 0.08 * dt;
          if (flashes[i].life <= 0) flashes.splice(i, 1);
        }

        updateStats();
      }

      const bgColor = isAI() ? "transparent" : "#07090d";
      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = bgColor;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Death zone line
        ctx.strokeStyle = "rgba(255, 90, 122, 0.2)";
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(0, canvas.height - 4);
        ctx.lineTo(canvas.width, canvas.height - 4);
        ctx.stroke();

        // Brick danger zone — red dashed line where bricks cause game over
        ctx.save();
        ctx.setLineDash([4, 6]);
        ctx.strokeStyle = "rgba(255, 90, 122, 0.12)";
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(0, DANGER_Y);
        ctx.lineTo(canvas.width, DANGER_Y);
        ctx.stroke();
        ctx.restore();

        // Bricks
        const gradient = ctx.createLinearGradient(0, 0, canvas.width, 0);
        gradient.addColorStop(0, "#27d6a0");
        gradient.addColorStop(0.55, "#64a8ff");
        gradient.addColorStop(1, "#ffd166");

        const rowColors = ["#c0c8d8", "#c0c8d8", gradient, gradient, gradient];

        for (const brick of bricks) {
          if (!brick.alive) continue;
          ctx.fillStyle = brick.maxHP > 1 ? rowColors[0] : gradient;
          ctx.globalAlpha = 0.9 - brick.row * 0.08;
          ctx.beginPath();
          const br = 3;
          ctx.moveTo(brick.x + br, brick.y);
          ctx.lineTo(brick.x + brick.w - br, brick.y);
          ctx.quadraticCurveTo(brick.x + brick.w, brick.y, brick.x + brick.w, brick.y + br);
          ctx.lineTo(brick.x + brick.w, brick.y + brick.h - br);
          ctx.quadraticCurveTo(brick.x + brick.w, brick.y + brick.h, brick.x + brick.w - br, brick.y + brick.h);
          ctx.lineTo(brick.x + br, brick.y + brick.h);
          ctx.quadraticCurveTo(brick.x, brick.y + brick.h, brick.x, brick.y + brick.h - br);
          ctx.lineTo(brick.x, brick.y + br);
          ctx.quadraticCurveTo(brick.x, brick.y, brick.x + br, brick.y);
          ctx.closePath();
          ctx.fill();
          ctx.globalAlpha = 1;

          // fortified border — brighter outline for multi-HP bricks
          if (brick.maxHP > 1) {
            const hpRatio = brick.hp / brick.maxHP;
            ctx.strokeStyle = `rgba(255, 255, 255, ${0.3 + hpRatio * 0.5})`;
            ctx.lineWidth = hpRatio * 2;
            ctx.beginPath();
            ctx.moveTo(brick.x + br, brick.y);
            ctx.lineTo(brick.x + brick.w - br, brick.y);
            ctx.quadraticCurveTo(brick.x + brick.w, brick.y, brick.x + brick.w, brick.y + br);
            ctx.lineTo(brick.x + brick.w, brick.y + brick.h - br);
            ctx.quadraticCurveTo(brick.x + brick.w, brick.y + brick.h, brick.x + brick.w - br, brick.y + brick.h);
            ctx.lineTo(brick.x + br, brick.y + brick.h);
            ctx.quadraticCurveTo(brick.x, brick.y + brick.h, brick.x, brick.y + brick.h - br);
            ctx.lineTo(brick.x, brick.y + br);
            ctx.quadraticCurveTo(brick.x, brick.y, brick.x + br, brick.y);
            ctx.closePath();
            ctx.stroke();
          }
        }

        // Brick destroy flashes
        for (const f of flashes) {
          ctx.fillStyle = `rgba(255, 255, 255, ${f.life * 0.6})`;
          ctx.fillRect(f.x, f.y, f.w, f.h);
        }

        // Particles
        for (const p of particles) {
          ctx.globalAlpha = p.life;
          ctx.fillStyle = p.color;
          ctx.fillRect(p.x - p.size / 2, p.y - p.size / 2, p.size, p.size);
        }
        ctx.globalAlpha = 1;

        // Paddle — rounded rectangle
        ctx.fillStyle = "#f4f6fb";
        const pr = 7;
        ctx.beginPath();
        ctx.moveTo(paddle.x + pr, paddle.y);
        ctx.lineTo(paddle.x + paddle.w - pr, paddle.y);
        ctx.quadraticCurveTo(paddle.x + paddle.w, paddle.y, paddle.x + paddle.w, paddle.y + pr);
        ctx.lineTo(paddle.x + paddle.w, paddle.y + paddle.h - pr);
        ctx.quadraticCurveTo(paddle.x + paddle.w, paddle.y + paddle.h, paddle.x + paddle.w - pr, paddle.y + paddle.h);
        ctx.lineTo(paddle.x + pr, paddle.y + paddle.h);
        ctx.quadraticCurveTo(paddle.x, paddle.y + paddle.h, paddle.x, paddle.y + paddle.h - pr);
        ctx.lineTo(paddle.x, paddle.y + pr);
        ctx.quadraticCurveTo(paddle.x, paddle.y, paddle.x + pr, paddle.y);
        ctx.closePath();
        ctx.fill();

        // Ball glow
        ctx.save();
        ctx.shadowColor = "#ff5a7a";
        ctx.shadowBlur = 12;
        ctx.beginPath();
        ctx.arc(ball.x, ball.y, ball.r, 0, Math.PI * 2);
        ctx.fillStyle = "#ff5a7a";
        ctx.fill();
        ctx.restore();

        // Ball core (brighter center)
        ctx.beginPath();
        ctx.arc(ball.x, ball.y, ball.r * 0.55, 0, Math.PI * 2);
        ctx.fillStyle = "#ff9eae";
        ctx.fill();

        // Start screen
        if (waiting && !done) {
          ctx.fillStyle = "rgba(7, 9, 13, 0.88)";
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          const pulse = 0.45 + 0.2 * Math.sin(Date.now() / 800);
          ctx.fillStyle = `rgba(244, 246, 251, ${pulse})`;
          ctx.font = "500 15px system-ui";
          ctx.textAlign = "center";
          const ty = canvas.height * 0.38;
          ctx.fillText("SPACE to start", canvas.width / 2, ty);
          ctx.strokeStyle = `rgba(255, 209, 102, ${pulse * 0.5})`;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(canvas.width / 2 - 50, ty + 14);
          ctx.lineTo(canvas.width / 2 + 50, ty + 14);
          ctx.stroke();
        }

        // Serve prompt
        if (serving && !done && !waiting) {
          ctx.fillStyle = "rgba(244, 246, 251, 0.5)";
          ctx.font = "500 14px system-ui";
          ctx.textAlign = "center";
          ctx.fillText("SPACE to serve", canvas.width / 2, canvas.height / 2 + 40);
        }

        // Game over overlay
        if (done) {
          ctx.fillStyle = "rgba(7, 9, 13, 0.72)";
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          const elapsed = gameStartTime > 0 ? (Date.now() - gameStartTime) / 1000 : 0;
          const apm = elapsed > 0 ? Math.round(actionCount / (elapsed / 60)) : 0;
          ctx.textAlign = "center";
          ctx.fillStyle = "#f4f6fb";
          ctx.font = "700 22px system-ui";
          ctx.fillText(String(score), canvas.width / 2, canvas.height / 2 - 24);
          ctx.fillStyle = "#7a8499";
          ctx.font = "400 12px system-ui";
          ctx.fillText(apm + " APM", canvas.width / 2, canvas.height / 2 + 4);
          ctx.fillStyle = "#aeb8ca";
          ctx.font = "400 14px system-ui";
          ctx.fillText("Press R to restart", canvas.width / 2, canvas.height / 2 + 32);
        }
      }

      function loop(now) {
        const dt = Math.min((now - (lastFrameTime || now)) / REF_DT, 3);
        lastFrameTime = now;
        update(dt);
        draw();
        requestAnimationFrame(loop);
      }

      resetGame();
      canvas.focus();
      loop(performance.now());

      if (window.location.search.includes("embed")) {
        document.body.classList.add("embed");
        canvas.focus();
      }
      postScores();
    </script>
  </body>
</html>
</file>

