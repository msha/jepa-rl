      }
      body.embed canvas {
        width: 100%;
        height: auto;
        aspect-ratio: 4 / 3;
        background: transparent;
        border-color: transparent;
      }

      header, #status {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
      }

      header.hidden-default {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 10px;
      }

      h1 {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
      }

      .stats {
        display: flex;
        gap: 14px;
        font-variant-numeric: tabular-nums;
        font-size: 14px;
      }

      canvas {
        display: block;
        width: 100%;
        aspect-ratio: 4 / 3;
        background: #07090d;
        border: 1px solid #2d3442;
        outline: none;
      }

      #status {
        min-height: 22px;
        margin-top: 8px;
        color: #aeb8ca;
        font-size: 13px;
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>JEPA-RL Asteroids</h1>
        <div class="stats">
          <span>Score <strong id="score">0</strong></span>
          <span>Lives <strong id="lives">3</strong></span>
        </div>
      </header>
      <canvas id="game" width="640" height="480" tabindex="0"></canvas>
      <div id="status" data-state="playing">Playing</div>
    </main>

    <script>
      const canvas = document.getElementById("game");
      const ctx = canvas.getContext("2d");
      const scoreEl = document.getElementById("score");
      const livesEl = document.getElementById("lives");
      const statusEl = document.getElementById("status");

      const W = canvas.width;
      const H = canvas.height;
      const SHIP_SIZE = 14;
      const TURN_SPEED = 0.065;
      const THRUST = 0.12;
      const FRICTION = 0.99;
      const MAX_SPEED = 5.5;
      const BULLET_SPEED = 7;
      const BULLET_LIFE = 50;
      const SHOOT_COOLDOWN = 14;
      const INVULN_TIME = 90;      // frames of invulnerability after respawn
      const ASTEROID_SPEED = 1.2;
      const POWERUP_CHANCE = 0.15;
      const POWERUP_LIFE = 600;
      const RAPID_DURATION = 300;
      const SCATTER_DURATION = 300;
      const SCATTER_ANGLE = 0.15;
      const SHIELD_DURATION = 180;
      const TOUGH_HP = { 3: 4, 2: 3, 1: 2 };
      const TOUGH_SHRINK = 0.82;
      const TOUGH_BREAK_CHANCE = 0.2;
      const MOSS_SPREAD = 0.35;
      const MOSS_REGEN = 0.004;
      const MOSS_HIT = 0.5;

      const REF_DT = 1000 / 60;
      let lastFrameTime = 0;

      const keys = new Set();
      let ship = null;
      let asteroids = [];
      let bullets = [];
      let particles = [];
      let flashEffects = [];
      let powerups = [];
      let buffs = { rapid: 0, shield: false, scatter: 0 };
      let score = 0;
      let lives = 3;
      let done = false;
      let waiting = true;
      let shootTimer = 0;
      let invulnTimer = 0;
      let wave = 1;
      let gameStartTime = 0;
      let actionCount = 0;
      const BOARD_KEY = "jeparl_asteroids";

      function postScores(scores) {
        try { window.parent.postMessage({ type: "jeparl-scores", game: BOARD_KEY, scores: scores || loadBoard() }, "*"); } catch {}
      }

      function isAI() { return new URLSearchParams(window.location.search).has("run_name"); }

      function getPlayerLabel() {
        const params = new URLSearchParams(window.location.search);
        if (isAI()) {
          const run = params.get("run_name") || "";
          const ckpt = params.get("checkpoint") || "";
          if (run && ckpt) return run + " · " + ckpt;
          if (run) return run;
          return "AI";
        }
        return params.get("player_name") || "HUMAN";
      }

      function getMetadata() {
        const params = new URLSearchParams(window.location.search);
        return {
          algorithm: params.get("algorithm") || "",
          encoder: params.get("encoder") || "",
          latent_dim: params.get("latent_dim") || "",
          steps_trained: params.get("steps_trained") || ""
        };
      }

      function loadBoard() {
        try { return JSON.parse(localStorage.getItem(BOARD_KEY) || "[]"); }
        catch { return []; }
      }

      function saveToBoard(s) {
        if (s <= 0) return loadBoard();
        const scores = loadBoard();
        const elapsed = gameStartTime > 0 ? (Date.now() - gameStartTime) / 1000 : 0;
        const apm = elapsed > 0 ? Math.round(actionCount / (elapsed / 60)) : 0;
        const entry = { score: s, player: getPlayerLabel(), type: isAI() ? "ai" : "human", date: new Date().toISOString(), apm: apm };
        if (isAI()) Object.assign(entry, getMetadata());
        scores.push(entry);
        scores.sort((a, b) => b.score - a.score);
        if (scores.length > 10) scores.length = 10;
        try { localStorage.setItem(BOARD_KEY, JSON.stringify(scores)); } catch {}
        postScores(scores);
        return scores;
      }

      function updateStats() {
        scoreEl.textContent = String(score);
        livesEl.textContent = String(lives);
      }

      function setDone(text) {
        done = true;
        saveToBoard(score);
        statusEl.dataset.state = "done";
        statusEl.textContent = text;
      }

      function resetShip() {
        ship = {
          x: W / 2, y: H / 2,
          vx: 0, vy: 0,
          angle: -Math.PI / 2,
        };
        invulnTimer = INVULN_TIME;
      }

      function createAsteroid(x, y, size, kind) {
        kind = kind || "normal";
        const isTough = kind === "tough";
        const isSlimy = kind === "slimy";
        const radius = size === 3 ? 40 : size === 2 ? 22 : 12;
        const speed = ASTEROID_SPEED * (0.5 + Math.random() * 0.8) * (4 - size) * 0.5;
        const angle = Math.random() * Math.PI * 2;
        const COLORS = isTough
          ? ["#a8896e", "#9b7d62", "#8a7060", "#b09478", "#7a6355"]
          : isSlimy
          ? ["#4a8a5a", "#3d7a4d", "#5a9a6a", "#3a6a4a", "#4d7a58"]
          : ["#8a94a6", "#9ea8b8", "#7a8499", "#b0a898", "#98a8b0", "#a89c8e"];
        const verts = [];
        const n = 8 + Math.floor(Math.random() * 5);
        for (let i = 0; i < n; i++) {
          const a = (i / n) * Math.PI * 2;
          const r = radius * (0.7 + Math.random() * 0.3);
          verts.push({ x: Math.cos(a) * r, y: Math.sin(a) * r });
        }
        return {
          x, y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          size, radius, baseRadius: radius, verts,
          rotAngle: 0,
          rotSpeed: (Math.random() - 0.5) * 0.04,
          color: COLORS[Math.floor(Math.random() * COLORS.length)],
          kind,
          hp: isTough ? TOUGH_HP[size] : 1,
          maxHp: isTough ? TOUGH_HP[size] : 1,
          moss: isSlimy ? 0.5 : 0,
          mossMax: isSlimy ? 1.0 : 0,
          cracks: [],
        };
      }

      function spawnWave() {
        const count = 2 + wave;
        for (let i = 0; i < count; i++) {
          const MARGIN = 50;
          let ax, ay;
          const edge = Math.floor(Math.random() * 4);
          if (edge === 0) { ax = -MARGIN; ay = Math.random() * H; }
          else if (edge === 1) { ax = W + MARGIN; ay = Math.random() * H; }
          else if (edge === 2) { ax = Math.random() * W; ay = -MARGIN; }
          else { ax = Math.random() * W; ay = H + MARGIN; }
          let kind = "normal";
          if (wave >= 3 && Math.random() < 0.2) kind = "slimy";
          else if (wave >= 2 && Math.random() < 0.25) kind = "tough";
          asteroids.push(createAsteroid(ax, ay, 3, kind));
        }
      }

      function dist(x1, y1, x2, y2) {
        const dx = x1 - x2;
        const dy = y1 - y2;
        return Math.sqrt(dx * dx + dy * dy);
      }

      function wrap(obj) {
        if (obj.x < -40) obj.x += W + 80;
        if (obj.x > W + 40) obj.x -= W + 80;
        if (obj.y < -40) obj.y += H + 80;
        if (obj.y > H + 40) obj.y -= H + 80;
      }

      function spawnParticles(x, y, color, count) {
        for (let i = 0; i < count; i++) {
          const angle = Math.random() * Math.PI * 2;
          const speed = 1 + Math.random() * 3;
          particles.push({
            x, y,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            life: 1.0,
            decay: 0.03 + Math.random() * 0.02,
            size: 1.5 + Math.random() * 2.5,
            color,
          });
        }
      }

      function spawnFlash(x, y, color, maxR) {
        flashEffects.push({ x, y, radius: 2, maxRadius: maxR || 40, color, life: 1.0 });
      }

      function resetGame() {
        score = 0;
        lives = 3;
        done = false;
        waiting = true;
        wave = 1;
        actionCount = 0;
        gameStartTime = 0;
        asteroids = [];
        bullets = [];
        particles = [];
        flashEffects = [];
        powerups = [];
        buffs = { rapid: 0, shield: false, scatter: 0 };
        resetShip();
        spawnWave();
        statusEl.dataset.state = "playing";
        statusEl.textContent = "Playing";
        updateStats();
      }

      function shipDestroyed() {
        lives -= 1;
        spawnParticles(ship.x, ship.y, "#ff5a7a", 40);
        spawnParticles(ship.x, ship.y, "#ffd166", 12);
        spawnFlash(ship.x, ship.y, "#ff5a7a", 50);
        if (lives <= 0) {
          setDone("Done");
        } else {
          resetShip();
          waiting = true;
          updateStats();
        }
      }

      window.addEventListener("keydown", (event) => {
        const k = event.key;
        const mapped = k === 'w' || k === 'W' ? 'ArrowUp'
                     : k === 'a' || k === 'A' ? 'ArrowLeft'
                     : k === 's' || k === 'S' ? 'ArrowDown'
                     : k === 'd' || k === 'D' ? 'ArrowRight'
                     : k;
        keys.add(mapped);
        if (!waiting && !done) actionCount++;
        if (mapped === " ") {
          event.preventDefault();
          if (waiting && !done) {
            waiting = false;
            gameStartTime = Date.now();
          }
        }
        if (mapped === "r" && done) {
          resetGame();
        }
        if (["ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight"].includes(mapped)) {
          event.preventDefault();
        }
      });

      window.addEventListener("keyup", (event) => {
        const k = event.key;
        const mapped = k === 'w' || k === 'W' ? 'ArrowUp'
                     : k === 'a' || k === 'A' ? 'ArrowLeft'
                     : k === 's' || k === 'S' ? 'ArrowDown'
                     : k === 'd' || k === 'D' ? 'ArrowRight'
                     : k;
        keys.delete(mapped);
      });

      function update(dt) {
        if (done) return;

        // Waiting to start/respawn — drift asteroids in background
        if (waiting) {
          for (const a of asteroids) {
            a.x += a.vx * 0.3 * dt;
            a.y += a.vy * 0.3 * dt;
            a.rotAngle += a.rotSpeed * dt;
            wrap(a);
          }
          updateParticles(dt);
          return;
        }

        // Ship controls
        if (keys.has("ArrowLeft")) ship.angle -= TURN_SPEED * dt;
        if (keys.has("ArrowRight")) ship.angle += TURN_SPEED * dt;
        if (keys.has("ArrowUp")) {
          ship.vx += Math.cos(ship.angle) * THRUST * dt;
          ship.vy += Math.sin(ship.angle) * THRUST * dt;
        }

        // Friction
        ship.vx *= Math.pow(FRICTION, dt);
        ship.vy *= Math.pow(FRICTION, dt);

        // Speed cap
        const spd = Math.sqrt(ship.vx * ship.vx + ship.vy * ship.vy);
        if (spd > MAX_SPEED) {
          ship.vx = (ship.vx / spd) * MAX_SPEED;
          ship.vy = (ship.vy / spd) * MAX_SPEED;
        }

        ship.x += ship.vx * dt;
        ship.y += ship.vy * dt;
        wrap(ship);

        // Shooting
        if (shootTimer > 0) shootTimer -= dt;
        const cooldown = buffs.rapid > 0 ? Math.floor(SHOOT_COOLDOWN / 2) : SHOOT_COOLDOWN;
        if (keys.has(" ") && shootTimer <= 0) {
          const angles = buffs.scatter > 0 ? [-SCATTER_ANGLE, 0, SCATTER_ANGLE] : [0];
          for (const off of angles) {
            const a = ship.angle + off;
            bullets.push({
              x: ship.x + Math.cos(a) * SHIP_SIZE,
              y: ship.y + Math.sin(a) * SHIP_SIZE,
              vx: Math.cos(a) * BULLET_SPEED + ship.vx * 0.3,
              vy: Math.sin(a) * BULLET_SPEED + ship.vy * 0.3,
              life: BULLET_LIFE,
            });
          }
          ship.vx -= Math.cos(ship.angle) * 0.25;
          ship.vy -= Math.sin(ship.angle) * 0.25;
          spawnParticles(ship.x - Math.cos(ship.angle) * SHIP_SIZE * 0.6, ship.y - Math.sin(ship.angle) * SHIP_SIZE * 0.6, "#ff5a7a", 3);
          shootTimer = cooldown;
        }

        // Invulnerability
        if (invulnTimer > 0) invulnTimer -= dt;

        // Update bullets
        for (let i = bullets.length - 1; i >= 0; i--) {
          const b = bullets[i];
          b.x += b.vx * dt;
          b.y += b.vy * dt;
          b.life -= dt;
          wrap(b);
          if (b.life <= 0) bullets.splice(i, 1);
        }

        // Update asteroids
        for (const a of asteroids) {
          a.x += a.vx * dt;
          a.y += a.vy * dt;
          a.rotAngle += a.rotSpeed * dt;
          wrap(a);
          // Moss regeneration
          if (a.moss > 0 && a.moss < (a.mossMax || 1)) {
            a.moss = Math.min(a.mossMax || 1, a.moss + MOSS_REGEN * dt);
          }
        }

        // Asteroid–asteroid collisions
        for (let i = 0; i < asteroids.length; i++) {
          for (let j = i + 1; j < asteroids.length; j++) {
            const a = asteroids[i];
            const b = asteroids[j];
            const d = dist(a.x, a.y, b.x, b.y);
            const minD = a.radius + b.radius;
            if (d < minD && d > 0.1) {
              // Skip if both off-screen
              const offA = a.x < -50 || a.x > W + 50 || a.y < -50 || a.y > H + 50;
              const offB = b.x < -50 || b.x > W + 50 || b.y < -50 || b.y > H + 50;
              if (offA && offB) continue;
              const nx = (b.x - a.x) / d;
              const ny = (b.y - a.y) / d;
              const overlap = minD - d;
              a.x -= nx * overlap * 0.5;
              a.y -= ny * overlap * 0.5;
              b.x += nx * overlap * 0.5;
              b.y += ny * overlap * 0.5;
              const dvx = a.vx - b.vx;
              const dvy = a.vy - b.vy;
              const dot = dvx * nx + dvy * ny;
              if (dot > 0) {
                a.vx -= nx * dot * 0.6;
                a.vy -= ny * dot * 0.6;
                b.vx += nx * dot * 0.6;
                b.vy += ny * dot * 0.6;
              }
              // Slimy moss spread
              const aSlimy = a.kind === "slimy";
              const bSlimy = b.kind === "slimy";
              if (aSlimy && b.kind !== "slimy") {
                b.moss = Math.min(1, b.moss + MOSS_SPREAD);
                b.mossMax = Math.max(b.mossMax, 1);
              }
              if (bSlimy && a.kind !== "slimy") {
                a.moss = Math.min(1, a.moss + MOSS_SPREAD);
                a.mossMax = Math.max(a.mossMax, 1);
              }
              spawnParticles((a.x + b.x) / 2, (a.y + b.y) / 2, aSlimy || bSlimy ? "#4a8a5a" : "#555", 2);
            }
          }
        }

        // Bullet–asteroid collisions
        for (let bi = bullets.length - 1; bi >= 0; bi--) {
          const b = bullets[bi];
          for (let ai = asteroids.length - 1; ai >= 0; ai--) {
            const a = asteroids[ai];
            if (dist(b.x, b.y, a.x, a.y) < a.radius) {
              // Moss absorbs hit
              if (a.moss > 0) {
                a.moss = Math.max(0, a.moss - MOSS_HIT);
                spawnParticles(b.x, b.y, "#4a8a5a", 6);
                spawnFlash(b.x, b.y, "#27d6a0", a.radius * 0.5);
                bullets.splice(bi, 1);
                score += 5;
                updateStats();
                break;
              }

              // Tough asteroid: multi-hit
              if (a.kind === "tough" && a.hp > 1) {
                a.hp -= 1;
                a.radius = Math.max(a.baseRadius * 0.45, a.radius * TOUGH_SHRINK);
                const ca = Math.random() * Math.PI * 2;
                a.cracks.push({
                  x1: Math.cos(ca) * a.radius * 0.2,
                  y1: Math.sin(ca) * a.radius * 0.2,
                  x2: Math.cos(ca + 0.2 + Math.random() * 0.4) * a.radius * 0.95,
                  y2: Math.sin(ca + 0.2 + Math.random() * 0.4) * a.radius * 0.95,
                });
                spawnParticles(b.x, b.y, "#a8896e", 8);
                spawnFlash(b.x, b.y, "#a8896e", a.radius);
                score += 5;

                // Chance to break early
                if (Math.random() < TOUGH_BREAK_CHANCE && a.size > 1) {
                  const pts = a.size === 3 ? 30 : 60;
                  score += pts;
                  spawnParticles(a.x, a.y, "#a8896e", 18);
                  spawnFlash(a.x, a.y, "#a8896e", a.radius * 1.5);
                  asteroids.push(createAsteroid(a.x, a.y, a.size - 1, "tough"));
                  asteroids.push(createAsteroid(a.x, a.y, a.size - 1));
                  asteroids.splice(ai, 1);
                }
                bullets.splice(bi, 1);
                updateStats();
                break;
              }

              // Destroy asteroid
              const pts = a.kind === "tough" ? (a.size === 3 ? 40 : a.size === 2 ? 80 : 120) : (a.size === 3 ? 20 : a.size === 2 ? 50 : 100);
              score += pts;
              const colors = a.kind === "tough" ? ["#a8896e", "#9b7d62", "#8a7060"] : a.kind === "slimy" ? ["#4a8a5a", "#3d7a4d", "#5a9a6a"] : ["#ffd166", "#ff5a7a", "#64a8ff"];
              const pCount = a.size === 3 ? 30 : a.size === 2 ? 18 : 10;
              spawnParticles(a.x, a.y, colors[a.size - 1] || colors[0], pCount);
              spawnParticles(a.x, a.y, "#ffffff", Math.floor(pCount / 3));
              spawnFlash(a.x, a.y, colors[a.size - 1] || colors[0], a.radius * 1.8);

              // Maybe drop power-up
              if (a.size >= 2 && Math.random() < POWERUP_CHANCE) {
                const types = ["rapid", "shield", "scatter"];
                powerups.push({
                  x: a.x, y: a.y,
                  type: types[Math.floor(Math.random() * types.length)],
                  life: POWERUP_LIFE,
                  phase: Math.random() * Math.PI * 2,
                });
              }

              // Split — children inherit moss
              if (a.size > 1) {
                const childKind = a.kind === "tough" ? "tough" : "normal";
                const c1 = createAsteroid(a.x, a.y, a.size - 1, childKind);
                const c2 = createAsteroid(a.x, a.y, a.size - 1, childKind);
                if (a.moss > 0) {
                  c1.moss = a.moss * 0.6; c1.mossMax = 1;
                  c2.moss = a.moss * 0.6; c2.mossMax = 1;
                }
                asteroids.push(c1);
                asteroids.push(c2);
              }
              asteroids.splice(ai, 1);
              bullets.splice(bi, 1);
              updateStats();
              break;
            }
          }
        }

        // Ship–asteroid collision
        if (invulnTimer <= 0) {
          for (const a of asteroids) {
            if (dist(ship.x, ship.y, a.x, a.y) < a.radius + SHIP_SIZE * 0.6) {
              if (buffs.shield) {
                buffs.shield = false;
                invulnTimer = SHIELD_DURATION;
                spawnParticles(ship.x, ship.y, "#64a8ff", 15);
                spawnFlash(ship.x, ship.y, "#64a8ff", 30);
              } else {
                shipDestroyed();
                return;
              }
            }
          }
        }

        // Power-up collection
        for (let i = powerups.length - 1; i >= 0; i--) {
          const p = powerups[i];
          p.life -= dt;
          p.phase += 0.05 * dt;
          if (p.life <= 0) { powerups.splice(i, 1); continue; }
          if (dist(ship.x, ship.y, p.x, p.y) < 18) {
            if (p.type === "rapid") buffs.rapid = RAPID_DURATION;
            else if (p.type === "shield") buffs.shield = true;
            else if (p.type === "scatter") buffs.scatter = SCATTER_DURATION;
            spawnParticles(p.x, p.y, p.type === "rapid" ? "#ffd166" : p.type === "shield" ? "#64a8ff" : "#27d6a0", 10);
            powerups.splice(i, 1);
          }
        }

        // Tick buffs
        if (buffs.rapid > 0) buffs.rapid -= dt;
        if (buffs.scatter > 0) buffs.scatter -= dt;

        // New wave
        if (asteroids.length === 0) {
          wave += 1;
          spawnWave();
        }

        updateParticles(dt);
      }

      function updateParticles(dt) {
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.x += p.vx * dt;
          p.y += p.vy * dt;
          p.vy += 0.03 * dt;
          p.life -= p.decay * dt;
          if (p.life <= 0) particles.splice(i, 1);
        }
        for (let i = flashEffects.length - 1; i >= 0; i--) {
          const f = flashEffects[i];
          f.radius += (f.maxRadius - f.radius) * 0.2 * dt;
          f.life -= 0.06 * dt;
          if (f.life <= 0) flashEffects.splice(i, 1);
        }
      }

      const bgColor = isAI() ? "transparent" : "#07090d";
      function draw() {
        ctx.clearRect(0, 0, W, H);
        ctx.fillStyle = bgColor;
        ctx.fillRect(0, 0, W, H);

        // Flash effects
        for (const f of flashEffects) {
          ctx.globalAlpha = f.life * 0.5;
          ctx.strokeStyle = f.color;
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.arc(f.x, f.y, f.radius, 0, Math.PI * 2);
          ctx.stroke();
        }
        ctx.globalAlpha = 1;

        // Asteroids
        for (const a of asteroids) {
          const drawScale = a.kind === "tough" ? a.radius / a.baseRadius : 1;
          ctx.save();
          ctx.translate(a.x, a.y);
          ctx.rotate(a.rotAngle);
          ctx.scale(drawScale, drawScale);
          ctx.strokeStyle = a.color;
          ctx.lineWidth = a.kind === "tough" ? 2.2 : 1.5;
          ctx.beginPath();
          ctx.moveTo(a.verts[0].x, a.verts[0].y);
          for (let i = 1; i < a.verts.length; i++) {
            ctx.lineTo(a.verts[i].x, a.verts[i].y);
          }
          ctx.closePath();
          ctx.stroke();

          // Tough cracks
          if (a.cracks.length) {
            ctx.strokeStyle = "#c47a5a";
            ctx.lineWidth = 1;
            for (const c of a.cracks) {
              ctx.beginPath();
              ctx.moveTo(c.x1, c.y1);
              ctx.lineTo(c.x2, c.y2);
              ctx.stroke();
            }
          }

          // Moss overlay
          if (a.moss > 0) {
            ctx.globalAlpha = a.moss * 0.55;
            ctx.fillStyle = "#3a7a4a";
            ctx.beginPath();
            ctx.moveTo(a.verts[0].x, a.verts[0].y);
            for (let i = 1; i < a.verts.length; i++) {
              ctx.lineTo(a.verts[i].x, a.verts[i].y);
            }
            ctx.closePath();
            ctx.fill();
            // Mossy glow for slimy
            if (a.kind === "slimy") {
              ctx.shadowColor = "#4a8a5a";
              ctx.shadowBlur = 8 * a.moss;
              ctx.strokeStyle = "#5aaa6a";
              ctx.lineWidth = 1;
              ctx.beginPath();
              ctx.moveTo(a.verts[0].x, a.verts[0].y);
              for (let i = 1; i < a.verts.length; i++) {
                ctx.lineTo(a.verts[i].x, a.verts[i].y);
              }
              ctx.closePath();
              ctx.stroke();
              ctx.shadowBlur = 0;
            }
            ctx.globalAlpha = 1;
          }

          ctx.restore();
        }

        // Power-ups
        for (const p of powerups) {
          const bob = Math.sin(p.phase) * 3;
          const color = p.type === "rapid" ? "#ffd166" : p.type === "shield" ? "#64a8ff" : "#27d6a0";
          const pulse = 0.7 + Math.sin(p.phase * 2) * 0.3;
          ctx.save();
          ctx.globalAlpha = pulse * Math.min(1, p.life / 60);
          ctx.translate(p.x, p.y + bob);
          ctx.shadowColor = color;
          ctx.shadowBlur = 8;
          ctx.fillStyle = color;
          ctx.beginPath();
          const s = 6;
          ctx.moveTo(0, -s); ctx.lineTo(s, 0); ctx.lineTo(0, s); ctx.lineTo(-s, 0);
          ctx.closePath();
          ctx.fill();
          ctx.shadowBlur = 0;
          ctx.globalAlpha = 1;
          ctx.restore();
        }

        // Bullets
        for (const b of bullets) {
          ctx.save();
          ctx.shadowColor = "#ffd166";
          ctx.shadowBlur = 6;
          ctx.fillStyle = "#ffd166";
          ctx.beginPath();
          ctx.arc(b.x, b.y, 2.5, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
        }

        // Ship
        if (ship && (!waiting || done)) {
          const blink = invulnTimer > 0 && Math.floor(invulnTimer / 4) % 2 === 0;
          if (!blink) {
            ctx.save();
            ctx.translate(ship.x, ship.y);
            ctx.rotate(ship.angle);

            // Thrust flame
            if (keys.has("ArrowUp") && !waiting && !done) {
              ctx.fillStyle = "#ff5a7a";
              ctx.globalAlpha = 0.6 + Math.random() * 0.4;
              ctx.beginPath();
              ctx.moveTo(-SHIP_SIZE * 0.5, -SHIP_SIZE * 0.3);
              ctx.lineTo(-SHIP_SIZE * (0.9 + Math.random() * 0.5), 0);
              ctx.lineTo(-SHIP_SIZE * 0.5, SHIP_SIZE * 0.3);
              ctx.closePath();
              ctx.fill();
              ctx.globalAlpha = 1;
            }

            // Ship body
            ctx.strokeStyle = "#f4f6fb";
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(SHIP_SIZE, 0);
            ctx.lineTo(-SHIP_SIZE * 0.7, -SHIP_SIZE * 0.6);
            ctx.lineTo(-SHIP_SIZE * 0.4, 0);
            ctx.lineTo(-SHIP_SIZE * 0.7, SHIP_SIZE * 0.6);
            ctx.closePath();
            ctx.stroke();

            ctx.restore();
          }

          // Shield aura
          if (buffs.shield) {
            ctx.save();
            ctx.strokeStyle = "#64a8ff";
            ctx.globalAlpha = 0.3 + Math.sin(Date.now() * 0.006) * 0.15;
            ctx.lineWidth = 1.5;
            ctx.beginPath();
            ctx.arc(ship.x, ship.y, SHIP_SIZE + 5, 0, Math.PI * 2);
            ctx.stroke();
            ctx.globalAlpha = 1;
            ctx.restore();
          }

          // Buff indicators
          const activeBuffs = [];
          if (buffs.rapid > 0) activeBuffs.push({ color: "#ffd166", label: "R" });
          if (buffs.scatter > 0) activeBuffs.push({ color: "#27d6a0", label: "S" });
          for (let bi = 0; bi < activeBuffs.length; bi++) {
            const bx = ship.x + 18 + bi * 12;
            const by = ship.y - 18;
            ctx.save();
            ctx.fillStyle = activeBuffs[bi].color;
            ctx.globalAlpha = 0.7;
            ctx.font = "600 8px system-ui";
            ctx.textAlign = "center";
            ctx.fillText(activeBuffs[bi].label, bx, by);
            ctx.globalAlpha = 1;
            ctx.restore();
          }
        }

        // Particles
        for (const p of particles) {
          ctx.globalAlpha = p.life;
          ctx.fillStyle = p.color;
          ctx.fillRect(p.x - p.size / 2, p.y - p.size / 2, p.size, p.size);
        }
        ctx.globalAlpha = 1;

        // Start screen
        if (waiting && !done) {
          ctx.fillStyle = "rgba(7, 9, 13, 0.45)";
          ctx.fillRect(0, 0, W, H);
          const pulse = 0.45 + 0.2 * Math.sin(Date.now() / 800);
          ctx.fillStyle = `rgba(244, 246, 251, ${pulse})`;
          ctx.font = "500 15px system-ui";
          ctx.textAlign = "center";
          ctx.fillText("SPACE to start", W / 2, H * 0.38);
          ctx.strokeStyle = `rgba(255, 209, 102, ${pulse * 0.5})`;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(W / 2 - 50, H * 0.38 + 14);
          ctx.lineTo(W / 2 + 50, H * 0.38 + 14);
          ctx.stroke();
        }

        // Game over overlay
        if (done) {
          ctx.fillStyle = "rgba(7, 9, 13, 0.72)";
          ctx.fillRect(0, 0, W, H);
          const elapsed = gameStartTime > 0 ? (Date.now() - gameStartTime) / 1000 : 0;
          const apm = elapsed > 0 ? Math.round(actionCount / (elapsed / 60)) : 0;
          ctx.textAlign = "center";
          ctx.fillStyle = "#f4f6fb";
          ctx.font = "700 22px system-ui";
          ctx.fillText(String(score), W / 2, H / 2 - 24);
          ctx.fillStyle = "#7a8499";
          ctx.font = "400 12px system-ui";
          ctx.fillText(apm + " APM", W / 2, H / 2 + 4);
          ctx.fillStyle = "#aeb8ca";
          ctx.font = "400 14px system-ui";
          ctx.fillText("Press R to restart", W / 2, H / 2 + 32);
        }
      }

      function loop(now) {
        const dt = Math.min((now - (lastFrameTime || now)) / REF_DT, 3);
        lastFrameTime = now;
        update(dt);
        draw();
        requestAnimationFrame(loop);
      }

      resetGame();
      canvas.focus();
      loop(performance.now());

      if (window.location.search.includes("embed")) {
        document.body.classList.add("embed");
        canvas.focus();
      }
      postScores();
    </script>
  </body>
</html>
</file>

<file path="games/snake/index.html">
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>JEPA-RL Snake</title>
    <style>
      :root {
        color-scheme: dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #111318;
        color: #f4f6fb;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
      }

      main {
        width: min(92vw, 720px);
      }

      body.embed {
        overflow: hidden;
        min-height: auto;
        background: transparent;
      }
      body.embed main {
        width: 100%;
      }
      body.embed header, body.embed #status {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
      }
      body.embed canvas {
        width: 100%;
        height: auto;
        aspect-ratio: 4 / 3;
        background: transparent;
        border-color: transparent;
      }

      header, #status {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
      }

      header.hidden-default {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 10px;
      }

      h1 {
        margin: 0;
        font-size: 18px;
        font-weight: 700;
      }

      .stats {
        display: flex;
        gap: 14px;
        font-variant-numeric: tabular-nums;
        font-size: 14px;
      }

      canvas {
        display: block;
        width: 100%;
        aspect-ratio: 4 / 3;
        background: #07090d;
        border: 1px solid #2d3442;
        outline: none;
      }

      #status {
        min-height: 22px;
        margin-top: 8px;
        color: #aeb8ca;
        font-size: 13px;
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>JEPA-RL Snake</h1>
        <div class="stats">
          <span>Score <strong id="score">0</strong></span>
          <span>Lives <strong id="lives">3</strong></span>
        </div>
      </header>
      <canvas id="game" width="640" height="480" tabindex="0"></canvas>
      <div id="status" data-state="playing">Playing</div>
    </main>

    <script>
      const canvas = document.getElementById("game");
      const ctx = canvas.getContext("2d");
      const scoreEl = document.getElementById("score");
      const livesEl = document.getElementById("lives");
      const statusEl = document.getElementById("status");

      const CELL = 20;
      const COLS = canvas.width / CELL;   // 32
      const ROWS = canvas.height / CELL;  // 24
      const BASE_INTERVAL = 120;          // ms between moves at start
      const MIN_INTERVAL = 55;            // fastest speed
      const SPEED_STEP = 2;               // ms faster per food eaten

      let snake = [];
      let direction = { x: 1, y: 0 };
      let nextDirection = { x: 1, y: 0 };
      let food = null;
      let score = 0;
      let lives = 3;
      let done = false;
      let waiting = true;   // waiting for Space to start
      let lastMove = 0;
      let lastFrameTime = 0;
      const REF_DT = 1000 / 60;
      let particles = [];
      let gameStartTime = 0;
      let actionCount = 0;
      const BOARD_KEY = "jeparl_snake";

      function postScores(scores) {
        try { window.parent.postMessage({ type: "jeparl-scores", game: BOARD_KEY, scores: scores || loadBoard() }, "*"); } catch {}
      }

      function isAI() { return new URLSearchParams(window.location.search).has("run_name"); }

      function getPlayerLabel() {
        const params = new URLSearchParams(window.location.search);
        if (isAI()) {
          const run = params.get("run_name") || "";
          const ckpt = params.get("checkpoint") || "";
          if (run && ckpt) return run + " · " + ckpt;
          if (run) return run;
          return "AI";
        }
        return params.get("player_name") || "HUMAN";
      }

      function getMetadata() {
        const params = new URLSearchParams(window.location.search);
        return {
          algorithm: params.get("algorithm") || "",
          encoder: params.get("encoder") || "",
          latent_dim: params.get("latent_dim") || "",
          steps_trained: params.get("steps_trained") || ""
        };
      }

      function loadBoard() {
        try { return JSON.parse(localStorage.getItem(BOARD_KEY) || "[]"); }
        catch { return []; }
      }

      function saveToBoard(s) {
        if (s <= 0) return loadBoard();
        const scores = loadBoard();
        const elapsed = gameStartTime > 0 ? (Date.now() - gameStartTime) / 1000 : 0;
        const apm = elapsed > 0 ? Math.round(actionCount / (elapsed / 60)) : 0;
        const entry = { score: s, player: getPlayerLabel(), type: isAI() ? "ai" : "human", date: new Date().toISOString(), apm: apm };
        if (isAI()) Object.assign(entry, getMetadata());
        scores.push(entry);
        scores.sort((a, b) => b.score - a.score);
        if (scores.length > 10) scores.length = 10;
        try { localStorage.setItem(BOARD_KEY, JSON.stringify(scores)); } catch {}
        postScores(scores);
        return scores;
      }

      function interval() {
        return Math.max(MIN_INTERVAL, BASE_INTERVAL - score * SPEED_STEP);
      }

      function resetSnake() {
        const cx = Math.floor(COLS / 2);
        const cy = Math.floor(ROWS / 2);
        snake = [
          { x: cx, y: cy },
          { x: cx - 1, y: cy },
          { x: cx - 2, y: cy },
        ];
        direction = { x: 1, y: 0 };
        nextDirection = { x: 1, y: 0 };
      }

      function spawnFood() {
        const occupied = new Set(snake.map((s) => `${s.x},${s.y}`));
        const free = [];
        for (let x = 0; x < COLS; x++) {
          for (let y = 0; y < ROWS; y++) {
            if (!occupied.has(`${x},${y}`)) free.push({ x, y });
          }
        }
        if (free.length === 0) {
          // board full — you win
          setDone("Done");
          return;
        }
        food = free[Math.floor(Math.random() * free.length)];
      }

      function spawnParticles(x, y, color, count) {
        for (let i = 0; i < count; i++) {
          const angle = Math.random() * Math.PI * 2;
          const speed = 1 + Math.random() * 2.5;
          particles.push({
            x: x * CELL + CELL / 2,
            y: y * CELL + CELL / 2,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            life: 1.0,
            decay: 0.04 + Math.random() * 0.02,
            size: 2 + Math.random() * 3,
            color,
          });
        }
      }

      function updateStats() {
        scoreEl.textContent = String(score);
        livesEl.textContent = String(lives);
      }

      function setDone(text) {
        done = true;
        saveToBoard(score);
        statusEl.dataset.state = "done";
        statusEl.textContent = text;
      }

      function resetGame() {
        score = 0;
        lives = 3;
        done = false;
        waiting = true;
        actionCount = 0;
        gameStartTime = 0;
        particles = [];
        resetSnake();
        spawnFood();
        statusEl.dataset.state = "playing";
        statusEl.textContent = "Playing";
        updateStats();
      }

      function die() {
        lives -= 1;
        spawnParticles(snake[0].x, snake[0].y, "#ff5a7a", 12);
        if (lives <= 0) {
          setDone("Done");
        } else {
          resetSnake();
          spawnFood();
          waiting = true;
          updateStats();
        }
      }

      function moveSnake() {
        direction = nextDirection;
        const head = { x: snake[0].x + direction.x, y: snake[0].y + direction.y };

        // Wall collision
        if (head.x < 0 || head.x >= COLS || head.y < 0 || head.y >= ROWS) {
          die();
          return;
        }

        // Self collision
        for (const seg of snake) {
          if (seg.x === head.x && seg.y === head.y) {
            die();
            return;
          }
        }

        snake.unshift(head);

        // Food
        if (food && head.x === food.x && head.y === food.y) {
          score += 10;
          spawnParticles(food.x, food.y, "#27d6a0", 8);
          spawnFood();
          updateStats();
        } else {
          snake.pop();
        }
      }

      window.addEventListener("keydown", (event) => {
        const k = event.key;
        const mapped = k === 'w' || k === 'W' ? 'ArrowUp'
                     : k === 'a' || k === 'A' ? 'ArrowLeft'
                     : k === 's' || k === 'S' ? 'ArrowDown'
                     : k === 'd' || k === 'D' ? 'ArrowRight'
                     : k;
        if (mapped === " ") {
          event.preventDefault();
          if (waiting && !done) {
            waiting = false;
            gameStartTime = Date.now();
            lastMove = performance.now();
          }
        }
        if (mapped === "r" && done) {
          resetGame();
        }
        if (done || waiting) return;
        actionCount++;

        switch (mapped) {
          case "ArrowUp":
            if (direction.y !== 1) nextDirection = { x: 0, y: -1 };
            event.preventDefault();
            break;
          case "ArrowDown":
            if (direction.y !== -1) nextDirection = { x: 0, y: 1 };
            event.preventDefault();
            break;
          case "ArrowLeft":
            if (direction.x !== 1) nextDirection = { x: -1, y: 0 };
            event.preventDefault();
            break;
          case "ArrowRight":
            if (direction.x !== -1) nextDirection = { x: 1, y: 0 };
            event.preventDefault();
            break;
        }
      });

      function update(now) {
        if (done) return;

        const dt = Math.min((now - (lastFrameTime || now)) / REF_DT, 3);
        lastFrameTime = now;

        if (waiting) return;

        if (now - lastMove >= interval()) {
          moveSnake();
          lastMove = now;
        }

        // Update particles
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.x += p.vx * dt;
          p.y += p.vy * dt;
          p.vy += 0.05 * dt;
          p.life -= p.decay * dt;
          if (p.life <= 0) particles.splice(i, 1);
        }
      }

      let tick = 0;

      const bgColor = isAI() ? "transparent" : "#07090d";
      function draw() {
        tick++;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = bgColor;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        // Food — pulsing glow
        if (food) {
          const fx = food.x * CELL + CELL / 2;
          const fy = food.y * CELL + CELL / 2;
          const pulse = 1 + 0.15 * Math.sin(tick * 0.08);
          ctx.save();
          ctx.shadowColor = "#27d6a0";
          ctx.shadowBlur = 14 * pulse;
          ctx.fillStyle = "#27d6a0";
          ctx.beginPath();
          ctx.arc(fx, fy, (CELL / 2 - 2) * pulse, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();
          ctx.fillStyle = "#a7f5d8";
          ctx.beginPath();
          ctx.arc(fx, fy, CELL / 4, 0, Math.PI * 2);
          ctx.fill();
        }

        // Snake body — connected segments with gradient
        for (let i = snake.length - 1; i >= 0; i--) {
          const seg = snake[i];
          const t = i / Math.max(1, snake.length - 1); // 0=head, 1=tail
          const pad = i === 0 ? 1 : 2;

          // Color gradient: bright head → dim tail
          const alpha = 1 - t * 0.55;
          const r = Math.round(68 + 80 * (1 - t));
          const g = Math.round(160 + 60 * (1 - t));
          const b = Math.round(255);
          ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;

          // Rounded rect
          const br = i === 0 ? 5 : 4;
          const sx = seg.x * CELL + pad;
          const sy = seg.y * CELL + pad;
          const sw = CELL - pad * 2;
          const sh = CELL - pad * 2;
          ctx.beginPath();
          ctx.moveTo(sx + br, sy);
          ctx.lineTo(sx + sw - br, sy);
          ctx.quadraticCurveTo(sx + sw, sy, sx + sw, sy + br);
          ctx.lineTo(sx + sw, sy + sh - br);
          ctx.quadraticCurveTo(sx + sw, sy + sh, sx + sw - br, sy + sh);
          ctx.lineTo(sx + br, sy + sh);
          ctx.quadraticCurveTo(sx, sy + sh, sx, sy + sh - br);
          ctx.lineTo(sx, sy + br);
          ctx.quadraticCurveTo(sx, sy, sx + br, sy);
          ctx.closePath();
          ctx.fill();

          // Connect adjacent segments with a filled rect so there are no gaps
          if (i > 0) {
            const prev = snake[i - 1];
            const dx = prev.x - seg.x;
            const dy = prev.y - seg.y;
            if (Math.abs(dx) <= 1 && Math.abs(dy) <= 1) {
              ctx.fillRect(
                Math.min(seg.x, prev.x) * CELL + pad,
                Math.min(seg.y, prev.y) * CELL + pad,
                (Math.abs(dx) + 1) * CELL - pad * 2,
                (Math.abs(dy) + 1) * CELL - pad * 2,
              );
            }
          }
        }

        // Head glow + eyes
        if (snake.length > 0) {
          const h = snake[0];
          const hx = h.x * CELL + CELL / 2;
          const hy = h.y * CELL + CELL / 2;
          ctx.save();
          ctx.shadowColor = "#64a8ff";
          ctx.shadowBlur = 8;
          ctx.fillStyle = "rgba(100, 168, 255, 0.25)";
          ctx.beginPath();
          ctx.arc(hx, hy, CELL / 2 + 2, 0, Math.PI * 2);
          ctx.fill();
          ctx.restore();

          // Eyes
          const eyeR = 2.5;
          const eyeOff = 4;
          ctx.fillStyle = "#f4f6fb";
          let e1x, e1y, e2x, e2y;
          if (direction.x === 1)       { e1x = hx+3; e1y = hy-eyeOff; e2x = hx+3; e2y = hy+eyeOff; }
          else if (direction.x === -1) { e1x = hx-3; e1y = hy-eyeOff; e2x = hx-3; e2y = hy+eyeOff; }
          else if (direction.y === -1) { e1x = hx-eyeOff; e1y = hy-3; e2x = hx+eyeOff; e2y = hy-3; }
          else                         { e1x = hx-eyeOff; e1y = hy+3; e2x = hx+eyeOff; e2y = hy+3; }
          ctx.beginPath(); ctx.arc(e1x, e1y, eyeR, 0, Math.PI*2); ctx.fill();
          ctx.beginPath(); ctx.arc(e2x, e2y, eyeR, 0, Math.PI*2); ctx.fill();
          // Pupils
          ctx.fillStyle = "#07090d";
          ctx.beginPath(); ctx.arc(e1x + direction.x*0.8, e1y + direction.y*0.8, 1.2, 0, Math.PI*2); ctx.fill();
          ctx.beginPath(); ctx.arc(e2x + direction.x*0.8, e2y + direction.y*0.8, 1.2, 0, Math.PI*2); ctx.fill();
        }

        // Particles
        for (const p of particles) {
          ctx.globalAlpha = p.life;
          ctx.fillStyle = p.color;
          ctx.fillRect(p.x - p.size / 2, p.y - p.size / 2, p.size, p.size);
        }
        ctx.globalAlpha = 1;

        // Overlays — minimal, just prompts
        if (waiting && !done) {
          ctx.fillStyle = "rgba(7, 9, 13, 0.75)";
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          const pulse = 0.45 + 0.2 * Math.sin(Date.now() / 800);
          ctx.fillStyle = `rgba(244, 246, 251, ${pulse})`;
          ctx.font = "500 15px system-ui";
          ctx.textAlign = "center";
          const msg = lives < 3 ? `Lives: ${lives} · SPACE to continue` : "SPACE to start";
          const ty = canvas.height * 0.38;
          ctx.fillText(msg, canvas.width / 2, ty);
          ctx.strokeStyle = `rgba(255, 209, 102, ${pulse * 0.5})`;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(canvas.width / 2 - 50, ty + 14);
          ctx.lineTo(canvas.width / 2 + 50, ty + 14);
          ctx.stroke();
        }

        if (done) {
          ctx.fillStyle = "rgba(7, 9, 13, 0.72)";
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          const elapsed = gameStartTime > 0 ? (Date.now() - gameStartTime) / 1000 : 0;
          const apm = elapsed > 0 ? Math.round(actionCount / (elapsed / 60)) : 0;
          ctx.textAlign = "center";
          ctx.fillStyle = "#f4f6fb";
          ctx.font = "700 22px system-ui";
          ctx.fillText(String(score), canvas.width / 2, canvas.height / 2 - 24);
          ctx.fillStyle = "#7a8499";
          ctx.font = "400 12px system-ui";
          ctx.fillText(apm + " APM", canvas.width / 2, canvas.height / 2 + 4);
          ctx.fillStyle = "#aeb8ca";
          ctx.font = "400 13px system-ui";
          ctx.fillText("Press R to restart", canvas.width / 2, canvas.height / 2 + 32);
        }
      }

      function loop(now) {
        update(now);
        draw();
        requestAnimationFrame(loop);
      }

      resetGame();
      canvas.focus();
      loop(performance.now());

      if (window.location.search.includes("embed")) {
        document.body.classList.add("embed");
        canvas.focus();
      }
      postScores();
    </script>
  </body>
</html>
