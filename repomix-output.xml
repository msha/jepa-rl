def test_config_accepts_joint_jepa_dqn_algorithm(tmp_path):
    """Config parser must accept joint_jepa_dqn as a valid algorithm."""
    config = _load_smoke_config(tmp_path)
    assert config.agent.algorithm == "joint_jepa_dqn"


