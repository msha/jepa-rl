      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
      }

      main {
        width: min(92vw, 720px);
      }

      body.embed {
        overflow: hidden;
        min-height: auto;
        background: transparent;
      }
      body.embed main {
        width: 100%;
      }
      body.embed header, body.embed #status {
        position: absolute;
        width: 1px;
        height: 1px;
