  reset_javascript: null

observation:
  mode: screenshot
  width: 160
  height: 120
  grayscale: false
  frame_stack: 4
  dom_selectors:
    score: "#score"
    lives: "#lives"
  crop: null
  normalize: true

reward:
  type: score_delta
  score_reader: dom
  score_selector: "#score"
  survival_bonus: 0.0
  idle_penalty: 0.0
  zero_score_patience_steps: 120
