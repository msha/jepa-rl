                    f"  - {Path('configs/base.yaml').resolve()}",
                    "game:",
                    "  reset_javascript: window.resetGame()",
                    "reward:",
                    "  privileged: false",
                ]
            ),
            encoding="utf-8",
        )

        with pytest.raises(ConfigError, match="javascript reset"):
            load_config(config_file)

    def test_privileged_default_in_reward_config(self):
